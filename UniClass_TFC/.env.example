# ─── Geral ─────────────────────────────────────────────────────
SECRET_KEY=coloque-uma-chave-secreta-aqui
DEBUG=False
ALLOWED_HOSTS=seu-projeto.up.railway.app,localhost

# ─── Banco de Dados MySQL (local: porta 33061 / produção AWS RDS: porta 3306) ─
DB_ENGINE=django.db.backends.mysql
DB_NAME=uniclass_tfc
DB_USER=seu_usuario_mysql
DB_PASSWORD=sua_senha_mysql
DB_HOST=127.0.0.1
DB_PORT=33061

# ─── E-mail (Gmail SMTP) ───────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu.email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app-16-chars
DEFAULT_FROM_EMAIL=UniClass <seu.email@gmail.com>

# ─── AWS S3 (para arquivos de media em produção) ───────────────
USE_S3=True
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=uniclass-media
AWS_S3_REGION_NAME=us-east-1
